import sqlite3


class Memory:

    def __init__(self):

        self.db = sqlite3.connect(
            "memory.db"
        )

        self.create()


    def create(self):

        cursor = self.db.cursor()

        cursor.execute(
            """
            CREATE TABLE IF NOT EXISTS memory
            (
                key TEXT,
                value TEXT
            )
            """
        )

        self.db.commit()


    def save(self, key, value):

        cursor = self.db.cursor()

        cursor.execute(
            "INSERT INTO memory VALUES (?,?)",
            (key,value)
        )

        self.db.commit()


    def get(self, key):

        cursor = self.db.cursor()

        cursor.execute(
            "SELECT value FROM memory WHERE key=?",
            (key,)
        )

        data = cursor.fetchone()


        if data:
            return data[0]

        return None
